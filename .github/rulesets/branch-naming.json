{
  "name": "Git-flow branch naming",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    }
  ],
  "conditions": {
    "ref_name": {
      "include": ["~ALL"],
      "exclude": ["refs/heads/main", "refs/heads/develop"]
    }
  },
  "rules": [
    {
      "type": "branch_name_pattern",
      "parameters": {
        "name": "Git-flow naming",
        "operator": "regex",
        "pattern": "^(feature|release|hotfix|bugfix|support|chore|docs)/.+$",
        "negate": false
      }
    }
  ]
}
