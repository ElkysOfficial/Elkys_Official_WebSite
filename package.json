{
  "name": "elkys website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/generate-sitemap.cjs && node scripts/prerender.cjs && node scripts/copy-htaccess.cjs && node scripts/copy-lnk-proxy.cjs",
    "build:min": "cross-env MINIFY=true vite build && node scripts/generate-sitemap.cjs && node scripts/prerender.cjs && node scripts/copy-htaccess.cjs && node scripts/copy-lnk-proxy.cjs",
    "build:dev": "vite build --mode development && node scripts/generate-sitemap.cjs && node scripts/prerender.cjs && node scripts/copy-htaccess.cjs && node scripts/copy-lnk-proxy.cjs",
    "preview": "vite preview",
    "update-logos": "node scripts/update-logos.cjs",
    "preview:emails": "node scripts/preview-emails.mjs",
    "generate-sitemap": "node scripts/generate-sitemap.cjs",
    "prerender": "node scripts/prerender.cjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emailjs/browser": "^4.4.1",
    "@hookform/resolvers": "^3.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-query": "^5.56.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.26.2",
    "recharts": "^3.8.1",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.59.1",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.20",
    "cheerio": "^1.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.47",
    "prettier": "^3.7.3",
    "purgecss": "^8.0.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.97.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.11",
    "terser": "^5.44.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-svgr": "^4.5.0"
  }
}
